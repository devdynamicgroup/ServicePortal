# Water Motion OCR Service — local environment
# Copy to .env and adjust. Existing process env vars always win (e.g. tests).
#
# Engine: mock | paddle | easyocr
OCR_ENGINE=paddle

# Required on Windows profiles with non-ASCII usernames (Paddle Inference path bug)
PADDLE_PDX_CACHE_HOME=C:\paddlex_cache

OCR_HOST=0.0.0.0
OCR_PORT=5055
