PORT=3040

# Local: development (enables session-secret fallback when AUTH_SESSION_SECRET is empty)
# Production/Render: set NODE_ENV=production and require AUTH_SESSION_SECRET
NODE_ENV=development

# App login (fixed users). Optional JSON overrides the built-in demo accounts.
# AUTH_USERS_JSON=[{"username":"admin","password":"admin123","name":"Admin","role":"Operations"}]

# Session HMAC secret for /api/auth/login tokens (protects Drive APIs).
# - Required in production / on Render — server refuses to start if missing.
# - Leave empty for local development (NODE_ENV=development) to use a warning-only fallback.
# - Generate: openssl rand -hex 32
# - Never commit real secrets (.env is gitignored).
AUTH_SESSION_SECRET=

# Drive upload audit rotation (metadata-only JSONL under ./data)
# DRIVE_AUDIT_MAX_BYTES=2097152
# DRIVE_AUDIT_KEEP_FILES=5

GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Drive (Service Account)
# Share both folders with the service account email (Editor).
# Main: visit/display photos (tap, visual, meter, chlorine, payment slip)
GOOGLE_DRIVE_MAIN_FOLDER_ID=1-mS_IbW95JGqbD9JZFvpIRkSxTjCjLXH
# Data: secondary/raw/OCR/internal captures
GOOGLE_DRIVE_DATA_FOLDER_ID=14Fug6zCjbtBt6I9ab4R-bWOo1FXRkHQx
# Legacy alias for main folder (optional if GOOGLE_DRIVE_MAIN_FOLDER_ID is set)
# GOOGLE_DRIVE_FOLDER_ID=1-mS_IbW95JGqbD9JZFvpIRkSxTjCjLXH
# Local path to the JSON key file (recommended). Absolute or relative to project root.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-service-account.json
# Alternative for hosts like Render: paste the full JSON in one line instead of a file path.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
# Optional: set anyone-with-link reader on each uploaded file (default false)
GOOGLE_DRIVE_MAKE_PUBLIC=false
# Optional timeout for Google token/Drive API calls (milliseconds)
# GOOGLE_DRIVE_FETCH_TIMEOUT_MS=60000

# Google Business Profile API (required for review sync)
GOOGLE_BUSINESS_CLIENT_ID=your-google-oauth-client-id
GOOGLE_BUSINESS_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_BUSINESS_REDIRECT_URI=http://localhost:3040/api/google-business/oauth/callback
GOOGLE_BUSINESS_REFRESH_TOKEN=your-google-business-refresh-token
GOOGLE_BUSINESS_ACCOUNT_ID=your-google-business-account-id
GOOGLE_BUSINESS_LOCATION_ID=your-google-business-location-id
GOOGLE_BUSINESS_LOCATION_NAME=Water Motion
GOOGLE_REVIEWS_PAGE_SIZE=50
GOOGLE_REVIEW_SYNC_ENABLED=true
GOOGLE_REVIEW_SYNC_INTERVAL_MINUTES=15
GOOGLE_REVIEW_SYNC_RUN_ON_START=true
NOTION_API_KEY=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id
# Main Client Feedback database used by close-case -> feedback form flow.
NOTION_CLIENT_FEEDBACK_DATABASE_ID=your-client-feedback-database-id
# Optional, only needed if the client feedback database has multiple data sources:
NOTION_CLIENT_FEEDBACK_DATA_SOURCE_ID=your-client-feedback-data-source-id
# Google Review sync can reuse the same database or point to a separate Google Reviews database.
NOTION_FEEDBACK_DATABASE_ID=your-client-feedback-database-id
# Optional, only needed if the feedback database has multiple data sources:
NOTION_FEEDBACK_DATA_SOURCE_ID=your-client-feedback-data-source-id
PUBLIC_BASE_URL=https://your-app.onrender.com
GOOGLE_REVIEW_URL=https://g.page/r/your-google-review-link/review
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_MOCK_SEND=true
CALCOM_API_KEY=your-calcom-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
AUTH_REDIRECT_URL=https://your-app.onrender.com/

# Optional: AI Suggest on Feedback page
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
