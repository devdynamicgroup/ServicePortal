###############################################################################
# Water Motion Service Portal — environment template
# Copy to .env (never commit .env — it is gitignored).
#
# IMPORTANT: Auth, Google Drive, and Google Business OAuth use DIFFERENT
# credentials. Do not substitute one for another.
###############################################################################

# =============================================================================
# RUNTIME
# =============================================================================
PORT=3040
# Local: development (session-secret fallback allowed when AUTH_SESSION_SECRET is empty)
# Production/Render: production (AUTH_SESSION_SECRET required — server exits if missing)
NODE_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:3040
# BIND_HOST=0.0.0.0

# =============================================================================
# AUTH / SESSION
# =============================================================================
# HMAC secret for /api/auth/login session tokens (also protects /api/drive/*).
# - Production / Render: REQUIRED (openssl rand -hex 32)
# - Local development: leave empty for a warned fallback only
# - Never commit a real value; never reuse GOOGLE_BUSINESS_CLIENT_SECRET here
AUTH_SESSION_SECRET=

# Optional login user override (JSON array). Built-in demo users used if empty.
# AUTH_USERS_JSON=[{"username":"admin","password":"admin123","name":"Admin","role":"Operations"}]

# IT contact shown on forgot-password (optional)
# IT_SUPPORT_CONTACT=IT Support: 02-000-0000
# IT_SUPPORT_LINE=@watermotion-it

# =============================================================================
# GOOGLE DRIVE  (OAuth 2.0 — uploads into the owner's My Drive)
# =============================================================================
# NOT a Service Account. NOT the same as Google Business OAuth below.
# Create an OAuth Client (Web application) in Google Cloud Console, enable Drive API,
# then visit /auth/google once to obtain GOOGLE_REFRESH_TOKEN.

GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must match an Authorized redirect URI on the OAuth client exactly:
GOOGLE_REDIRECT_URI=https://your-app.onrender.com/auth/google/callback
# Local example:
# GOOGLE_REDIRECT_URI=http://127.0.0.1:3040/auth/google/callback
GOOGLE_REFRESH_TOKEN=

GOOGLE_DRIVE_MAIN_FOLDER_ID=your-main-drive-folder-id
GOOGLE_DRIVE_DATA_FOLDER_ID=your-data-drive-folder-id
# Legacy alias for main: GOOGLE_DRIVE_FOLDER_ID=

GOOGLE_DRIVE_MAKE_PUBLIC=false
# DRIVE_AUDIT_MAX_BYTES=2097152
# DRIVE_AUDIT_KEEP_FILES=5

# =============================================================================
# GOOGLE BUSINESS / OAUTH  (review sync — separate OAuth client)
# =============================================================================
# Do NOT reuse GOOGLE_CLIENT_* Drive credentials here unless intentionally shared.

GOOGLE_BUSINESS_CLIENT_ID=your-google-oauth-client-id
GOOGLE_BUSINESS_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_BUSINESS_REDIRECT_URI=http://localhost:3040/api/google-business/oauth/callback
GOOGLE_BUSINESS_REFRESH_TOKEN=your-google-business-refresh-token
GOOGLE_BUSINESS_ACCOUNT_ID=your-google-business-account-id
GOOGLE_BUSINESS_LOCATION_ID=your-google-business-location-id
# GOOGLE_BUSINESS_LOCATION_NAME=Water Motion
GOOGLE_REVIEWS_PAGE_SIZE=50
GOOGLE_REVIEW_SYNC_ENABLED=true
GOOGLE_REVIEW_SYNC_INTERVAL_MINUTES=15
GOOGLE_REVIEW_SYNC_RUN_ON_START=true
GOOGLE_REVIEW_URL=https://g.page/r/your-google-review-link/review

# =============================================================================
# GOOGLE MAPS
# =============================================================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Debug scripts only:
# GOOGLE_API_KEY=
# GOOGLE_PLACE_ID=

# =============================================================================
# NOTION
# =============================================================================
NOTION_API_KEY=your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id
# NOTION_DATA_SOURCE_ID=
NOTION_CLIENT_FEEDBACK_DATABASE_ID=your-client-feedback-database-id
# NOTION_CLIENT_FEEDBACK_DATA_SOURCE_ID=
NOTION_FEEDBACK_DATABASE_ID=your-client-feedback-database-id
# NOTION_FEEDBACK_DATA_SOURCE_ID=

# =============================================================================
# LINE
# =============================================================================
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_MOCK_SEND=true

# =============================================================================
# OPTIONAL — AI Suggest (Feedback)
# =============================================================================
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# PLACEHOLDERS (not read by current runtime — safe to omit)
# =============================================================================
# CALCOM_API_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# AUTH_REDIRECT_URL=

# Full inventory: docs/ENVIRONMENT.md
# Drive setup: docs/GOOGLE_DRIVE.md
